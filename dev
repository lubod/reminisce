#!/bin/bash

# --- STRICT MODE ---
set -euo pipefail

# --- COLORS ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# --- CONFIG ---
PROJECT_NAME="reminisce-dev"
COMPOSE_FILE="docker/docker-compose-dev.yml"
OBS_FILE="docker/docker-compose-observability.yml"
DEV_CONFIG="config-dev.yaml"
FULL_CONFIG="config-fullstack.yaml"

# List of all possible container names to avoid naming conflicts
ALL_CONTAINERS="reminisce-dev-db reminisce-dev-geotagging reminisce-dev-ai-server reminisce-dev-server reminisce-dev-client p2p-dev-node-1 p2p-dev-node-2 p2p-dev-node-3 p2p-dev-node-4 p2p-dev-node-5"

# --- HELPERS ---
info() { echo -e "${BLUE}INFO:${NC} $1"; }
success() { echo -e "${GREEN}SUCCESS:${NC} $1"; }
warn() { echo -e "${YELLOW}WARN:${NC} $1"; }
error() { echo -e "${RED}ERROR:${NC} $1"; exit 1; }

check_tool() {
    if ! command -v "$1" &>/dev/null; then
        error "Required tool '$1' is not installed."
    fi
}

# --- LOAD ENVIRONMENT ---
if [ -f .env ]; then
    export $(grep -v '^#' .env | xargs)
fi

# --- COMMANDS ---
function show_help {
    echo -e "${GREEN}Reminisce Development Helper${NC}"
    echo "Usage: ./dev <command> [args]"
    echo ""
    echo "Infrastructure (Hybrid):"
    echo "  up, start              Start infra containers (DBs, AI, Nginx)"
    echo "  down, stop             Stop ALL containers and projects"
    echo "  recreate [svc...]      Force recreate infra containers"
    echo "  start-obs              Start observability stack (Grafana, Prometheus)"
    echo "  ps                     Show status of all containers"
    echo "  logs [svc...]          Follow logs"
    echo ""
    echo "Local App (Hybrid):"
    echo "  run                    Run Rust server locally"
    echo "  watch                  Auto-reload Rust server locally"
    echo "  client                 Start Vite dev server locally"
    echo "  test [args...]         Run Rust integration tests"
    echo "  e2e [args...]          Run Playwright e2e tests (requires dev stack running)"
    echo ""
    echo "Full Stack (Dockerized):"
    echo "  fullstack              Start everything in Docker"
    echo "  fullstack-recreate     Force recreate everything in Docker"
    echo ""
    echo "Docker & CI cache:"
    echo "  docker-build [imgs...] Build all or specific images"
    echo "  docker-rebuild [imgs...] Rebuild from scratch (no-cache)"
    echo "  docker-push [imgs...]  Push images to registry"
    echo ""
    echo "Maintenance:"
    echo "  clean                  Clean local build artifacts"
    echo "  clean-docker           Force remove all project containers & volumes"
    echo "  restore <file>         Restore database from backup"
    echo "  shell <svc>            Get shell into a container"
}

check_service_health() {
    local service_container=$1
    local status=$(docker inspect --format='{{.State.Health.Status}}' "$service_container" 2>/dev/null || echo "unhealthy")
    if [ "$status" == "healthy" ]; then return 0; else return 1; fi
}

function start_infra {
    info "Starting infrastructure..."
    docker compose --project-directory . -p "$PROJECT_NAME" -f "$COMPOSE_FILE" up -d --remove-orphans \
        postgres geotagging-db ai-server client storage-node-1 storage-node-2
    
    info "Waiting for databases to be healthy..."
    local count=0
    while [ $count -lt 30 ]; do
        if check_service_health "reminisce-dev-db" && check_service_health "reminisce-dev-geotagging"; then
            success "Infrastructure is ready!"
            break
        fi
        echo -n "."
        sleep 2
        count=$((count+1))
    done
    
    mkdir -p uploaded_images uploaded_videos data/p2p/shards
}

# --- MAIN LOGIC ---
COMMAND=${1:-""}
[ -n "$COMMAND" ] && shift

case "$COMMAND" in
    up|start) start_infra ;;
    down|stop)
        info "Stopping all projects and cleaning up..."
        # Stop under the current project name
        docker compose --project-directory . -p "$PROJECT_NAME" -f "$COMPOSE_FILE" down 2>/dev/null || true
        # Stop under the old project name (to fix conflicts)
        docker compose --project-directory . -p "reminisce-fullstack" -f "$COMPOSE_FILE" down 2>/dev/null || true
        # Stop observability
        docker compose --project-directory . -p "$PROJECT_NAME" -f "$OBS_FILE" down 2>/dev/null || true
        # Force remove any remaining containers by name
        docker rm -f $ALL_CONTAINERS 2>/dev/null || true
        success "Stopped and cleaned everything."
        ;;
    clean-docker)
        warn "This will remove ALL project containers and volumes. Continue? [y/N]"
        read -r response
        if [[ "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
            docker compose --project-directory . -p "$PROJECT_NAME" -f "$COMPOSE_FILE" down -v --remove-orphans
            docker compose --project-directory . -p "reminisce-fullstack" -f "$COMPOSE_FILE" down -v 2>/dev/null || true
            docker rm -f $ALL_CONTAINERS 2>/dev/null || true
            success "Docker environment wiped clean."
        else
            info "Cleanup cancelled."
        fi
        ;;
    recreate)
        info "Recreating infrastructure..."
        docker compose --project-directory . -p "$PROJECT_NAME" -f "$COMPOSE_FILE" up -d --force-recreate "$@"
        ;;
    ps)
        docker compose --project-directory . -p "$PROJECT_NAME" -f "$COMPOSE_FILE" ps
        ;;
    logs)
        docker compose --project-directory . -p "$PROJECT_NAME" -f "$COMPOSE_FILE" logs -f "$@"
        ;;
    shell)
        [ -z "${1:-""}" ] && error "Usage: ./dev shell <service_name>"
        docker exec -it "$1" /bin/bash || docker exec -it "$1" /bin/sh
        ;;
    run)
        check_tool "cargo"
        [ ! -f "$DEV_CONFIG" ] && error "$DEV_CONFIG not found. Copy it from .example"
        RUST_LOG=info cargo run --bin reminisce -- "$DEV_CONFIG" "$@"
        ;;
    watch)
        check_tool "cargo-watch"
        RUST_LOG=info cargo watch -x "run --bin reminisce -- $DEV_CONFIG" "$@"
        ;;
    client)
        check_tool "npm"
        cd client && npm run dev
        ;;
    test)
        check_tool "cargo"
        export PGHOST=localhost PGPORT=5432 PGUSER=postgres PGPASSWORD=postgres
        cargo test "$@"
        ;;
    e2e)
        check_tool "npx"
        cd e2e && npx playwright test "$@"
        ;;
    fullstack)
        info "Starting full application stack..."
        [ ! -f "$FULL_CONFIG" ] && error "$FULL_CONFIG not found. Copy it from .example"
        docker compose --project-directory . -p "$PROJECT_NAME" -f "$COMPOSE_FILE" up -d
        success "Access UI: https://localhost:28444"
        ;;
    fullstack-recreate)
        info "Recreating full application stack..."
        docker compose --project-directory . -p "$PROJECT_NAME" -f "$COMPOSE_FILE" up -d --force-recreate "$@"
        ;;
    docker-build)
        info "Building Docker images..."
        docker compose --project-directory . -f docker/docker-compose-build.yml build "$@"
        ;;
    docker-rebuild)
        info "Rebuilding Docker images from scratch..."
        docker compose --project-directory . -f docker/docker-compose-build.yml build --no-cache "$@"
        ;;
    docker-push)
        info "Pushing images to registry..."
        docker compose --project-directory . -f docker/docker-compose-build.yml push "$@"
        ;;
    build)
        info "Building local release binary..."
        cargo build --release "$@"
        ;;
    clean)
        info "Cleaning local artifacts..."
        cargo clean
        ;;
    restore)
        [ -z "${1:-""}" ] && error "Usage: ./dev restore <backup_file>"
        RUST_LOG=info cargo run --bin reminisce -- restore "$DEV_CONFIG" "$1"
        ;;
    start-obs)
        info "Starting observability..."
        docker compose --project-directory . -p "$PROJECT_NAME" -f "$OBS_FILE" up -d
        success "Grafana: http://localhost:3000"
        ;;
    *)
        show_help
        exit 1
        ;;
esac
