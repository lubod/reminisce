# NetBird overlay network (required for P2P storage)
NETBIRD_SETUP_KEY=your-setup-key-from-netbird-dashboard
NETBIRD_MANAGEMENT_URL=https://your-netbird-server.example.com
NETBIRD_OVERLAY_IP=100.64.0.1

# PostgreSQL credentials
# Defaults (postgres/postgres) are fine for local dev; set strong values in production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
