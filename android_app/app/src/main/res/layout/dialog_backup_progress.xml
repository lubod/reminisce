<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/progressDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/backup_in_progress"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:textColor="?android:attr/textColorPrimary" />

    <TextView
        android:id="@+id/overallProgressLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Overall Progress"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"
        android:textColor="?android:attr/textColorSecondary" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:max="100" />

    <TextView
        android:id="@+id/fileProgressLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Current File"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"
        android:textColor="?android:attr/textColorSecondary" />

    <ProgressBar
        android:id="@+id/fileProgressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:max="100" />

    <TextView
        android:id="@+id/progressText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/starting_backup"
        android:textAlignment="textStart"
        android:layout_marginBottom="8dp"
        android:gravity="start"
        android:textSize="13sp"
        android:textColor="?android:attr/textColorPrimary"
        android:maxLines="4"
        android:minLines="4"
        android:ellipsize="end" />

    <!-- Statistics Section -->
    <LinearLayout
        android:id="@+id/statsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:padding="12dp"
        android:background="@android:color/transparent">

        <TextView
            android:id="@+id/statsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload Summary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorPrimary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total files:"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary" />
            <TextView
                android:id="@+id/statsTotalFiles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Uploaded:"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary" />
            <TextView
                android:id="@+id/statsUploaded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#4CAF50" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Skipped:"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary" />
            <TextView
                android:id="@+id/statsSkipped"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF9800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Failed:"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary" />
            <TextView
                android:id="@+id/statsFailed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#F44336" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/cancelButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:text="Cancel Upload"
        android:backgroundTint="#F44336"
        android:textColor="@android:color/white" />

</LinearLayout>